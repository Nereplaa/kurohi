# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/anime_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-random-32-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Iyzico Payment ───────────────────────────────────────────────────────────
# Leave IYZICO_API_KEY empty to run in mock mode (no real Iyzico calls).
# Get sandbox keys from: https://sandbox-merchant.iyzipay.com
IYZICO_API_KEY=sandbox-your-api-key-here
IYZICO_SECRET_KEY=your-secret-key-here
IYZICO_BASE_URL=sandbox-api.iyzipay.com

# ── Local Video Streaming ────────────────────────────────────────────────────
# Absolute path to the folder containing your .mp4/.mkv demo files.
# Leave empty to disable the /stream endpoint.
# Windows example: VIDEO_DIR=C:/Users/YourName/Videos/anime
# Linux example:   VIDEO_DIR=/home/yourname/videos/anime
VIDEO_DIR=

# ── URLs ─────────────────────────────────────────────────────────────────────
# CALLBACK_URL must be publicly reachable by Iyzico (use ngrok for local dev)
CALLBACK_URL=https://your-ngrok-subdomain.ngrok-free.app/api/payments/callback
FRONTEND_URL=http://localhost:3000
