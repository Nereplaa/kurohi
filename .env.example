# Root-level .env.example — copy relevant sections to backend/.env and frontend/.env.local
#
# Backend: copy to backend/.env
# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/anime_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=replace-this-with-a-random-32-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Iyzico Payment ────────────────────────────────────────────────────────────
IYZICO_API_KEY=sandbox-your-api-key-here
IYZICO_SECRET_KEY=your-secret-key-here
IYZICO_BASE_URL=sandbox-api.iyzipay.com

# ── URLs ──────────────────────────────────────────────────────────────────────
CALLBACK_URL=https://your-ngrok-subdomain.ngrok-free.app/api/payments/callback
FRONTEND_URL=http://localhost:3000

# Frontend: copy to frontend/.env.local
# ── API ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
